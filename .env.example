# Perizia Analyzer v2 — Environment Variables
# Copy this to .env and fill in the values. NEVER commit real values.

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-secret-min-32-chars
NEXTAUTH_URL=https://your-vercel-deployment.vercel.app

# ── Anthropic Claude ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis (Redis Cloud eu-central-1 / Upstash fallback) ──────────────────
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ── AWS ──────────────────────────────────────────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=your-s3-bucket-name

# ── Limits ────────────────────────────────────────────────────────────────
MAX_PDF_MB=15
ANALYZE_TIMEOUT_MS=90000
